a) Find the average salary of instructors in the Computer Science department:
SELECT AVG(I.salary) AS AverageSalary
FROM INSTRUCTOR I
JOIN DEPARTMENT D
ON I.dept_id = D.dept_id
WHERE D.name = 'Computer Science';

b) Find the average salary in each department:
SELECT D.name AS Department,
       AVG(I.salary) AS AverageSalary
FROM DEPARTMENT D
JOIN INSTRUCTOR I
ON D.dept_id = I.dept_id
GROUP BY D.name;

c) Total salary of teachers earning more than 30000
SELECT SUM(salary) AS TotalSalary
FROM INSTRUCTOR
WHERE salary > 30000;

d) Number of students enrolled in each course
SELECT C.course_id,
       C.title,
       COUNT(T.student_id) AS EnrolledStudents
FROM COURSE C
LEFT JOIN SECTION S
ON C.course_id = S.course_id
LEFT JOIN TAKES T
ON S.section_id = T.section_id
GROUP BY C.course_id, C.title;

e) Departments whose building contains "Symbio"
SELECT name
FROM DEPARTMENT
WHERE building LIKE '%Symbio%';

f) Departments whose name contains "sci" (case insensitive)
SELECT name
FROM DEPARTMENT
WHERE LOWER(name) LIKE '%sci%';

g) Display length of student names
SELECT name,
       LENGTH(name) AS NameLength
FROM STUDENT;

h) Total number of instructors
SELECT COUNT(*) AS TotalInstructors
FROM INSTRUCTOR;

i) Add hiredate column, insert rows, display instructors working for past 5 years
Add column
ALTER TABLE INSTRUCTOR
ADD hiredate DATE;
