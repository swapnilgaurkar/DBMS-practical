CREATE TABLE Employees (
    emp_id NUMBER PRIMARY KEY,
    emp_name VARCHAR2(50),
    dept_id NUMBER,
    salary NUMBER(10, 2),
    manager_id NUMBER
);

CREATE TABLE Depts (
    dept_id NUMBER PRIMARY KEY,
    dept_name VARCHAR2(50),
    location VARCHAR2(50)
);

CREATE TABLE Projects (
    proj_id NUMBER PRIMARY KEY,
    proj_name VARCHAR2(50),
    dept_id NUMBER
);

CREATE TABLE Assignments (
    emp_id NUMBER,
    proj_id NUMBER,
    hours_worked NUMBER,
    CONSTRAINT pk_assignments PRIMARY KEY (emp_id, proj_id),
    CONSTRAINT fk_emp
        FOREIGN KEY (emp_id)
        REFERENCES Employees(emp_id),
    CONSTRAINT fk_proj
        FOREIGN KEY (proj_id)
        REFERENCES Projects(proj_id)
);

