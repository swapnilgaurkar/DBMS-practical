CREATE OR REPLACE PROCEDURE router_header_proc1 (
    routeid route_header.route_id%TYPE
) AS
    a NUMBER(7,2);
    b NUMBER(4);
BEGIN
    SELECT fare, distance 
    INTO a, b 
    FROM route_header 
    WHERE route_id = routeid;

    IF b <= 500 THEN
        UPDATE route_header 
        SET fare = 190.98 
        WHERE route_id = routeid;

        DBMS_OUTPUT.PUT_LINE('Fare updated to 190.98');

    ELSIF b > 500 AND b <= 1000 THEN
        UPDATE route_header 
        SET fare = 800.00 
        WHERE route_id = routeid;

        DBMS_OUTPUT.PUT_LINE('Fare updated to 800');

    ELSE
        DBMS_OUTPUT.PUT_LINE('Sorry, distance is too large.');
    END IF;

EXCEPTION
    WHEN NO_DATA_FOUND THEN
        DBMS_OUTPUT.PUT_LINE('Route ID not found');
END;
/

SET SERVEROUTPUT ON;
EXEC router_header_proc1(102);
