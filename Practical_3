Instructors working for past 5 years
SELECT name
FROM INSTRUCTOR
WHERE hiredate <= ADD_MONTHS(SYSDATE,-60);

j) Instructors who joined before 30-Jun-1990 or after 31-Dec-1990
SELECT name
FROM INSTRUCTOR
WHERE hiredate < DATE '1990-06-30'
OR hiredate > DATE '1990-12-31';

k) Instructors retiring on 01-Jan-2024 (max service 18 years)
SELECT name
FROM INSTRUCTOR
WHERE hiredate <= DATE '2006-01-01';

l) Instructors whose salary has at least 4 digits
SELECT name
FROM INSTRUCTOR
WHERE LENGTH(TO_CHAR(FLOOR(salary))) >= 4;

m) Salary classification using CASE
SELECT name,
       CASE
           WHEN salary < 60000 THEN 'Less Salary'
           WHEN salary = 60000 THEN 'Exact Salary'
           ELSE 'More Salary'
       END AS SalaryStatus
FROM INSTRUCTOR;
